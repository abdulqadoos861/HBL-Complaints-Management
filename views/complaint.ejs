<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Register Complaint</title>
  <style>
    body { font-family: Arial; padding: 20px; }
    .row { margin-bottom: 12px; }
    label { display:block; margin-bottom:6px; font-weight:600; }
    input, select, textarea { width: 320px; max-width: 100%; padding: 8px; }
    textarea { height: 90px; }
    button { padding: 10px 14px; cursor:pointer; }
    .dynamic-fields { padding: 12px; border: 1px solid #eee; margin-top: 10px; }
    .hint { color:#666; font-size: 12px; }
  </style>
</head>
<body>
  <h2>Register Complaint</h2>

  <div class="row">
    <label>Name</label>
    <input type="text" id="name" />
  </div>

  <div class="row">
    <label>CNIC</label>
    <input type="text" id="cnic" />
  </div>

  <div class="row">
    <label>Mobile</label>
    <input type="text" id="mobile" />
  </div>

  <div class="row">
    <label>Email</label>
    <input type="email" id="email" />
  </div>

  <hr />


  <div class="row">
    <label>Product Type</label>
    <select id="productType">
      <option value="">-- Select product --</option>
    </select>
  </div>

  <div class="row">
    <label>Category</label>
    <select id="category">
      <option value="">-- Select category --</option>
    </select>
  </div>

  <div class="dynamic-fields">
    <h3>Details</h3>
    <div id="dynamicFields"></div>
    <p class="hint">Fields shown depend on the selected Product.</p>
  </div>

  <hr />

  <div class="row">
    <label>Subject</label>
    <input type="text" id="subject" />
  </div>

  <div class="row">
    <label>Description</label>
    <textarea id="description"></textarea>
  </div>

  <div class="row">
    <label>Supporting Documents</label>
    <input type="file" id="docs" multiple />
    <div class="hint">Files will be sent as file names in this basic version.</div>
  </div>


  <div class="row">
    <button id="submitBtn" type="button">Submit Complaint</button>
  </div>

  <script>
    const $ = (id) => document.getElementById(id);

    const productTypeEl = $('productType');
    const categoryEl = $('category');
    const dynamicFieldsEl = $('dynamicFields');

    let allProducts = [];

    function clearSelect(selectEl) {
      while (selectEl.options.length) selectEl.remove(0);
    }

    function setCategoryDisabled(disabled) {
      categoryEl.disabled = disabled;
    }

    function setDynamicDisabled(disabled) {
      dynamicFieldsEl.style.opacity = disabled ? '0.6' : '1';
    }

    async function loadProducts() {
      const res = await fetch('/api/product/all');
      if (!res.ok) throw new Error('Failed to load products');
      allProducts = await res.json();

      clearSelect(productTypeEl);
      const placeholder = document.createElement('option');
      placeholder.value = '';
      placeholder.textContent = '-- Select product --';
      productTypeEl.appendChild(placeholder);

      for (const p of allProducts) {
        const opt = document.createElement('option');
        // productType in complaint model is a free string; we store slug as product type.
        opt.value = p._id;
        opt.textContent = p.label || p.slug;
        productTypeEl.appendChild(opt);
      }
    }

    async function loadCategories(productId) {
      // getcategory returns product.categories (array)
      const res = await fetch(`/api/category/${productId}`);
      if (!res.ok) throw new Error('Failed to load categories');

      const categories = await res.json();

      clearSelect(categoryEl);
      const placeholder = document.createElement('option');
      placeholder.value = '';
      placeholder.textContent = '-- Select category --';
      categoryEl.appendChild(placeholder);

      if (Array.isArray(categories)) {
        categories.forEach((c) => {
          const opt = document.createElement('option');
          // categories are stored as plain objects; handle multiple shapes defensively
          if (typeof c === 'string') {
            opt.value = c;
            opt.textContent = c;
          } else {
            // addproduct.ejs stores {name, description}
            const label = c.name || c.label || c.category || c.value || '';
            opt.value = label;
            opt.textContent = label || JSON.stringify(c);
          }
          if (opt.value) categoryEl.appendChild(opt);
        });
      }
    }

    function renderDynamicFields(fields) {
      dynamicFieldsEl.innerHTML = '';

      if (!Array.isArray(fields) || fields.length === 0) {
        dynamicFieldsEl.innerHTML = '<p>No dynamic fields for this product.</p>';
        return;
      }

      // Each inputfield has: label, name, type, required, placeholder, order
      // We will render all fields; category filtering can be added later if needed.
      fields
        .slice()
        .sort((a,b) => (a.order ?? 0) - (b.order ?? 0))
        .forEach((f) => {
          const wrapper = document.createElement('div');
          wrapper.className = 'row';

          const label = document.createElement('label');
          label.textContent = f.label || f.name;

          let input;
          const type = (f.type || 'text').toLowerCase();

          if (type === 'dropdown') {
            input = document.createElement('select');
            input.id = `df_${f.name}`;
            input.name = f.name;

            const opt0 = document.createElement('option');
            opt0.value = '';
            opt0.textContent = '-- Select --';
            input.appendChild(opt0);

            const options = Array.isArray(f.options) ? f.options : [];
            for (const o of options) {
              const opt = document.createElement('option');
              if (typeof o === 'string') {
                opt.value = o;
                opt.textContent = o;
              } else {
                const ov = o.value ?? o.name ?? o.label ?? '';
                opt.value = ov;
                opt.textContent = ov || JSON.stringify(o);
              }
              if (opt.value) input.appendChild(opt);
            }
          } else {
            input = document.createElement('input');
            input.type = type === 'palceholder' ? 'text' : (['number','date','text'].includes(type) ? type : 'text');
            input.id = `df_${f.name}`;
            input.name = f.name;
          }

          if (f.placeholder) input.placeholder = f.placeholder;
          if (f.required) input.required = true;

          wrapper.appendChild(label);
          wrapper.appendChild(input);
          dynamicFieldsEl.appendChild(wrapper);
        });
    }

    async function loadDynamicFields(productId) {
      const res = await fetch(`/api/inputFields/${productId}`);
      if (!res.ok) throw new Error('Failed to load input fields');
      const fields = await res.json();
      renderDynamicFields(fields);
    }

    async function refreshDependent() {
      const productId = productTypeEl.value;
      if (!productId) {
        clearSelect(categoryEl);
        const placeholder = document.createElement('option');
        placeholder.value = '';
        placeholder.textContent = '-- Select category --';
        categoryEl.appendChild(placeholder);

        dynamicFieldsEl.innerHTML = '';
        return;
      }

      setCategoryDisabled(false);
      setDynamicDisabled(false);

      await loadCategories(productId);
      await loadDynamicFields(productId);
    }

    async function submitComplaint() {
      const dynamicInputs = dynamicFieldsEl.querySelectorAll('[id^="df_"]');
      const details = {};

      dynamicInputs.forEach((el) => {
        const name = el.name || el.id.replace('df_', '');
        let val = el.value;
        // simple normalization
        if (el.type === 'number' && val !== '') val = Number(val);
        details[name] = val;
      });

      // complaint model expects category string and productType string.
      // We store productType as the selected product label.
      const selectedProduct = allProducts.find(p => p._id === productTypeEl.value);
      const productType = selectedProduct ? (selectedProduct.slug || selectedProduct.label) : '';

      if (!productType || !categoryEl.value) {
        alert('Please select Product Type and Category');
        return;
      }

      const formData = new FormData();

      formData.append('name', $('name').value);
      formData.append('cnic', $('cnic').value);
      formData.append('mobile', $('mobile').value);
      formData.append('email', $('email').value);

      formData.append('productType', productType);
      formData.append('category', categoryEl.value);

      formData.append('subject', $('subject').value);
      formData.append('description', $('description').value);

      // details must be string when sending multipart/form-data
      formData.append('details', JSON.stringify(details));
      formData.append('supportingDocs', JSON.stringify([]));

      // attach files
      const docsEl = $('docs');
      const files = docsEl?.files ? Array.from(docsEl.files) : [];
      for (const file of files) {
        formData.append('docs', file);
      }

      const res = await fetch('/complaint/create', {
        method: 'POST',
        body: formData
      });


      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.message || 'Failed to submit complaint');
      }

      alert('Complaint registered successfully');
      // basic reset
      $('subject').value = '';
      $('description').value = '';
    }

    productTypeEl.addEventListener('change', async () => {
      try {
        categoryEl.disabled = false;
        await refreshDependent();
      } catch (e) {
        alert(e.message);
      }
    });

    $('submitBtn').addEventListener('click', async () => {
      try {
        await submitComplaint();
      } catch (e) {
        alert(e.message);
      }
    });

    // init
    loadProducts().catch((e) => alert(e.message));
  </script>
</body>
</html>


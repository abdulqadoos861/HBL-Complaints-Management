<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Complaint Details</title>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family:Arial, sans-serif;
      background:#f4f6f9;
      padding:25px;
      color:#333;
    }

    .container{
      max-width:1100px;
      margin:auto;
    }

    .header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      margin-bottom:20px;
    }

    .header h1{
      color:#008269;
    }

    .back-btn{
      text-decoration:none;
      background:#008269;
      color:white;
      padding:10px 18px;
      border-radius:6px;
    }

    .card{
      background:white;
      padding:25px;
      border-radius:10px;
      margin-bottom:20px;
      box-shadow:0 2px 8px rgba(0,0,0,0.08);
    }

    .card h2{
      margin-bottom:20px;
      color:#008269;
      border-bottom:1px solid #eee;
      padding-bottom:10px;
    }

    .grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:15px;
    }

    .box{
      background:#fafafa;
      border:1px solid #e5e5e5;
      padding:15px;
      border-radius:8px;
    }

    .label{
      font-size:13px;
      color:#666;
      margin-bottom:6px;
    }

    .value{
      font-size:15px;
      font-weight:bold;
      word-break:break-word;
    }

    .description{
      background:#fafafa;
      padding:18px;
      border-radius:8px;
      line-height:1.7;
      border:1px solid #eee;
    }

    .attachment{
      display:block;
      text-decoration:none;
      color:#008269;
      padding:12px;
      background:#f8f8f8;
      border-radius:6px;
      margin-bottom:10px;
      border:1px solid #ddd;
    }

    .attachment:hover{
      background:#eefaf7;
    }

    .status{
      display:inline-block;
      background:#e8f5e9;
      color:#2e7d32;
      padding:5px 12px;
      border-radius:20px;
      font-size:13px;
      font-weight:bold;
    }

    #loading{
      text-align:center;
      font-size:22px;
      margin-top:50px;
    }

    @media(max-width:768px){

      .grid{
        grid-template-columns:1fr;
      }

      .header{
        flex-direction:column;
        gap:15px;
        align-items:flex-start;
      }

    }

    .form-group {
      margin-bottom: 15px;
    }

    .form-group label {
      display: block;
      font-weight: bold;
      margin-bottom: 5px;
      font-size: 14px;
    }

    .form-group select, .form-group input {
      width: 100%;
      padding: 10px;
      border: 1px solid #ddd;
      border-radius: 6px;
      background: white;
    }

  </style>

</head>

<body>

<div class="container">

  <!-- HEADER -->

  <div class="header">

    <h1>
      Complaint Details
    </h1>

    <a
      href="<%= userRole === 'admin' ? '/adminDashboard' : '/supportDashboard' %>"
      class="back-btn"
    >
      Back
    </a>

  </div>

  <!-- LOADING -->

  <div id="loading">
    Loading complaint...
  </div>

  <!-- CONTENT -->

  <div id="content" style="display:none;">

    <!-- BASIC INFO -->

    <div class="card">

      <h2 id="complaintNumber">
        Complaint
      </h2>

      <div
        class="grid"
        id="basicInfo"
      ></div>

    </div>

    <!-- DESCRIPTION -->

    <div class="card">

      <h2>Description</h2>

      <div
        id="description"
        class="description"
      ></div>

    </div>

    <!-- DETAILS -->

    <div class="card">

      <h2>Additional Details</h2>

      <div
        class="grid"
        id="details"
      ></div>

    </div>

    <!-- ATTACHMENTS -->

    <div class="card">

      <h2>Attachments</h2>

      <div id="attachments"></div>

    </div>

    <% if (userRole !== 'admin') { %>
    <!-- VERIFICATION FORM -->
    <div class="card">
      <h2>Verify & Assign</h2>
      <form id="verifyForm">
        <div class="grid">
          <div class="form-group">
            <label>Verification Status</label>
            <select id="verificationStatus" name="verificationStatus" required>
              <option value="Pending">Pending</option>
              <option value="Verified">Verified</option>
              <option value="Rejected">Rejected</option>
            </select>
          </div>
          <div class="form-group">
            <label>Priority</label>
            <select id="priority" name="priority">
              <option value="Low">Low</option>
              <option value="Medium" selected>Medium</option>
              <option value="High">High</option>
              <option value="Critical">Critical</option>
            </select>
          </div>
          <div class="form-group">
            <label>Assign to Department</label>
            <select id="assignedDepartment" name="assignedDepartment">
              <option value="">Select Department</option>
            </select>
          </div>
          <div class="form-group">
            <label>Assign to Employee</label>
            <select id="assignedTo" name="assignedTo">
              <option value="">Select Employee</option>
            </select>
          </div>
        </div>
        <div class="form-group" style="margin-top:15px;">
          <label>Internal Notes</label>
          <textarea id="internalNotes" name="internalNotes" style="width:100%; height:80px; padding:10px; border-radius:6px; border:1px solid #ccc; font-family: inherit;"></textarea>
        </div>
        <button type="submit" class="back-btn" style="border:none; cursor:pointer; margin-top:10px; width:100%; font-size: 16px; font-weight: bold;">Submit Verification</button>
      </form>
    </div>
    <% } %>

  </div>

</div>

<script>

const complaintId =
window.location.pathname.split('/').pop();



// SHORTCUT

function el(id){

  return document.getElementById(id);

}



// SAFE VALUE

function safe(value){

  return value || '-';

}



// CREATE BOX

function createBox(label,value){

  return `

    <div class="box">

      <div class="label">
        ${label}
      </div>

      <div class="value">
        ${safe(value)}
      </div>

    </div>

  `;

}



// LOAD COMPLAINT

async function loadComplaint(){

  try{

    const response =
      await fetch(
        `/complaint/complaints/${complaintId}`
      );

    const result =
      await response.json();

    const c =
      result.complaint;

    // SHOW CONTENT

    el('loading').style.display =
      'none';

    el('content').style.display =
      'block';

    // COMPLAINT NUMBER

    el('complaintNumber').innerText =
      `Complaint # ${c.complaintNumber}`;

    // BASIC INFO

    el('basicInfo').innerHTML =

      createBox('Customer Name',c.name) +

      createBox('CNIC',c.cnic) +

      createBox('Mobile',c.mobile) +

      createBox('Email',c.email) +

      createBox('Product Type',c.productType) +

      createBox('Category',c.category) +

      createBox(
        'Current Status',

        `<span class="status">
          ${safe(c.currentStep)}
        </span>`
      ) +

      createBox('Priority',c.priority) +

      createBox(
        'Verification Status',
        c.verificationStatus
      ) +

      createBox(
        'Department',
        c.assignedDepartment
      ) +

      createBox(
        'Assigned To',
        c.assignedTo?.name
      );

    // DESCRIPTION

    el('description').innerText =
      safe(c.description);

    // DETAILS

    let detailsHTML = '';

    for(let key in c.details){

      detailsHTML += createBox(

        key.replaceAll('_',' '),

        c.details[key]

      );

    }

    el('details').innerHTML =
      detailsHTML;

    // ATTACHMENTS

    let filesHTML = '';

    if(c.attachments){

      c.attachments.forEach(file => {

        filesHTML += `

          <a
            href="/uploads/${file}"
            target="_blank"
            class="attachment"
          >

            📎 ${file}

          </a>

        `;

      });

    }

    if(c.supportingDocs){

      c.supportingDocs.forEach(file => {

        filesHTML += `

          <a
            href="/uploads/${file}"
            target="_blank"
            class="attachment"
          >

            📄 ${file}

          </a>

        `;

      });

    }

    if(filesHTML === ''){

      filesHTML =
        '<div>No attachments available</div>';

    }

    el('attachments').innerHTML =
      filesHTML;

  }

  catch(error){

    console.log(error);

    el('loading').innerText =
      'Failed to load complaint';

  }

}



const userRole = '<%= userRole %>';

// INITIAL LOAD

loadComplaint();

if (userRole !== 'admin') {
    // LOAD DEPARTMENTS
    async function loadDepartments(){
      try {
        const res = await fetch('/complaint/departments');
        const departments = await res.json();
        const deptSelect = el('assignedDepartment');
        departments.forEach(d => {
          const opt = document.createElement('option');
          opt.value = d;
          opt.textContent = d;
          deptSelect.appendChild(opt);
        });
      } catch (e) { console.error('Failed to load departments', e); }
    }

    loadDepartments();

    // LOAD EMPLOYEES ON DEPT CHANGE
    el('assignedDepartment').addEventListener('change', async (e) => {
      const dept = e.target.value;
      const empSelect = el('assignedTo');
      empSelect.innerHTML = '<option value="">Select Employee</option>';
      
      if(!dept) return;

      try {
        const res = await fetch(`/complaint/employees?department=${encodeURIComponent(dept)}`);
        const employees = await res.json();
        employees.forEach(emp => {
          const opt = document.createElement('option');
          opt.value = emp._id;
          opt.textContent = `${emp.name} (${emp.designation})`;
          empSelect.appendChild(opt);
        });
      } catch (e) { console.error('Failed to load employees', e); }
    });

    // FORM SUBMISSION
    el('verifyForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData.entries());
      
      try {
        const res = await fetch(`/complaint/verify/${complaintId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        
        if (res.ok) {
          alert('Complaint verified and assigned successfully!');
          window.location.href = '/supportDashboard';
        } else {
          const err = await res.json();
          alert('Error: ' + err.message);
        }
      } catch (err) {
        alert('Network error');
      }
    });
}

</script>

</body>
</html>
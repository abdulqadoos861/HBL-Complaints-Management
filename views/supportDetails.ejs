<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>Complaint Details | HBL</title>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family:'Segoe UI',sans-serif;
      background:#f4f7f6;
      padding:25px;
      color:#333;
    }

    .container{
      max-width:1100px;
      margin:auto;
    }

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:center;
      margin-bottom:25px;
    }

    .back-btn{
      text-decoration:none;
      color:#008269;
      font-weight:bold;
    }

    .badge{
      background:#008269;
      color:white;
      padding:8px 16px;
      border-radius:20px;
      font-size:.85rem;
      font-weight:bold;
    }

    .card{
      background:white;
      border-radius:10px;
      padding:25px;
      margin-bottom:25px;
      box-shadow:0 2px 10px rgba(0,0,0,.06);
    }

    h2{
      color:#008269;
      margin-bottom:20px;
    }

    h3{
      margin-bottom:20px;
      color:#444;
    }

    .grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:20px;
    }

    .info{
      margin-bottom:18px;
    }

    .label{
      font-size:.85rem;
      color:#777;
      font-weight:bold;
      margin-bottom:5px;
      display:block;
    }

    .value{
      font-size:1rem;
      color:#222;
    }

    .description-box{
      background:#fafafa;
      border:1px solid #eee;
      padding:15px;
      border-radius:6px;
      white-space:pre-wrap;
      line-height:1.6;
    }

    select,
    textarea,
    input{
      width:100%;
      padding:12px;
      border:1px solid #ccc;
      border-radius:6px;
      margin-top:5px;
    }

    textarea{
      min-height:120px;
      resize:vertical;
    }

    .btn{
      border:none;
      padding:14px 22px;
      border-radius:6px;
      font-weight:bold;
      cursor:pointer;
    }

    .btn-primary{
      background:#008269;
      color:white;
    }

    .btn-danger{
      background:#e53935;
      color:white;
    }

    .btn-update{
      background:#4caf50;
      color:white;
      width:100%;
    }

    .actions{
      display:flex;
      gap:15px;
      margin-top:25px;
    }

    .attachment-link{
      display:block;
      margin-bottom:10px;
      text-decoration:none;
      color:#008269;
      font-weight:600;
    }

    .status-pill{
      display:inline-block;
      padding:6px 12px;
      border-radius:20px;
      background:#e8f5e9;
      color:#2e7d32;
      font-size:.85rem;
      font-weight:bold;
    }

    .update-card{
      border-left:4px solid #008269;
      background:#fafafa;
      padding:15px;
      margin-bottom:15px;
      border-radius:6px;
    }

    .loading{
      text-align:center;
      padding:60px;
      font-size:1.1rem;
    }

    .error{
      background:#ffebee;
      color:#c62828;
      padding:15px;
      border-radius:6px;
      margin-bottom:20px;
      display:none;
    }

  </style>

</head>

<body>

<div class="container">

  <div class="topbar">

    <a href="/employeeDashboard" class="back-btn">
      ← Back to Dashboard
    </a>

    <div class="badge">
      SUPPORT PORTAL
    </div>

  </div>

  <div id="error" class="error"></div>

  <div id="loading" class="loading">
    Loading complaint details...
  </div>

  <div id="content" style="display:none;">

    <!-- Complaint Info -->

    <div class="card">

      <h2>
        Complaint #
        <span id="complaintNumber"></span>
      </h2>

      <div class="grid">

        <div>

          <div class="info">
            <span class="label">Customer Name</span>
            <div class="value" id="name"></div>
          </div>

          <div class="info">
            <span class="label">CNIC</span>
            <div class="value" id="cnic"></div>
          </div>

          <div class="info">
            <span class="label">Mobile</span>
            <div class="value" id="mobile"></div>
          </div>

          <div class="info">
            <span class="label">Email</span>
            <div class="value" id="email"></div>
          </div>

        </div>

        <div>

          <div class="info">
            <span class="label">Product Type</span>
            <div class="value" id="productType"></div>
          </div>

          <div class="info">
            <span class="label">Category</span>
            <div class="value" id="category"></div>
          </div>

          <div class="info">
            <span class="label">Current Step</span>
            <div class="value">
              <span id="currentStepBadge" class="status-pill"></span>
            </div>
          </div>

          <div class="info">
            <span class="label">Priority</span>
            <div class="value" id="priorityText"></div>
          </div>

        </div>

      </div>

    </div>

    <!-- Description -->

    <div class="card">

      <h3>Description</h3>

      <div id="description" class="description-box"></div>

    </div>

    <!-- Dynamic Details -->

    <div class="card">

      <h3>Additional Details</h3>

      <div id="detailsContainer" class="grid"></div>

    </div>

    <!-- Attachments -->

    <div class="card">

      <h3>Attachments</h3>

      <div id="attachmentsContainer"></div>

    </div>

    <!-- Complaint Management -->

    <div class="card">

      <h3>Complaint Management</h3>

      <div class="grid">

        <div>

          <label>Verification Status</label>

          <select id="verificationStatus">
            <option value="Pending">Pending</option>
            <option value="Verified">Verified</option>
            <option value="Rejected">Rejected</option>
          </select>

        </div>

        <div>

          <label>Priority</label>

          <select id="priority">
            <option value="Low">Low</option>
            <option value="Medium">Medium</option>
            <option value="High">High</option>
            <option value="Critical">Critical</option>
          </select>

        </div>

      </div>

      <br>

      <label>Current Process Step</label>

      <select id="currentStep">
        <option value="Submitted">Submitted</option>
        <option value="Under Verification">Under Verification</option>
        <option value="Assigned">Assigned</option>
        <option value="In Progress">In Progress</option>
        <option value="Resolved">Resolved</option>
        <option value="Closed">Closed</option>
      </select>

    </div>

    <!-- Add Update -->

    <div class="card">

      <h3>Add Update</h3>

      <label>Status</label>

      <select id="updateStatus">
        <option value="Under Verification">Under Verification</option>
        <option value="In Progress">In Progress</option>
        <option value="Resolved">Resolved</option>
        <option value="Closed">Closed</option>
      </select>

      <br><br>

      <label>Resolution Notes</label>

      <textarea
        id="resolutionNotes"
        placeholder="Write complaint progress..."
      ></textarea>

      <br><br>

      <label>Attachment</label>

      <input type="file" id="attachment">

      <br><br>

      <button id="addUpdateBtn" class="btn btn-update">
        Add Update
      </button>

    </div>

    <!-- Actions -->

    <div class="actions">

      <button id="saveBtn" class="btn btn-primary">
        Save Changes
      </button>

      <button id="deleteBtn" class="btn btn-danger">
        Delete Complaint
      </button>

    </div>

  </div>

</div>

<script>

const complaintId =
window.location.pathname.split('/').pop();

const el = (id) =>
document.getElementById(id);

// SAFE VALUE

function safe(value){

  if(
    value === undefined ||
    value === null ||
    value === ''
  ){
    return '-';
  }

  return value;

}

// LOAD COMPLAINT

async function loadComplaint(){

  try{

    const res = await fetch(
      `/complaint/complaints/${complaintId}`
    );

    if(!res.ok){

      throw new Error(
        'Failed to load complaint'
      );

    }

    const response =
      await res.json();

    console.log(response);

    // BACKEND MAY RETURN:
    // { success:true, complaint:{} }

    const data =
      response.complaint || response;

    // =========================
    // BASIC INFORMATION
    // =========================

    el('complaintNumber').textContent =
      safe(data.complaintNumber);

    el('name').textContent =
      safe(data.name);

    el('cnic').textContent =
      safe(data.cnic);

    el('mobile').textContent =
      safe(data.mobile);

    el('email').textContent =
      safe(data.email);

    el('productType').textContent =
      safe(data.productType);

    el('category').textContent =
      safe(data.category);

    el('description').textContent =
      safe(data.description);

    el('currentStepBadge').textContent =
      safe(data.currentStep);

    el('priorityText').textContent =
      safe(data.priority);

    // =========================
    // SELECT VALUES
    // =========================

    el('verificationStatus').value =
      data.verificationStatus || 'Pending';

    el('priority').value =
      data.priority || 'Medium';

    el('currentStep').value =
      data.currentStep || 'Submitted';

    // =========================
    // DYNAMIC DETAILS
    // =========================

    const detailsContainer =
      el('detailsContainer');

    detailsContainer.innerHTML = '';

    // CASE 1
    // IF BACKEND RETURNS data.details

    if(
      data.details &&
      typeof data.details === 'object'
    ){

      Object.entries(data.details).forEach(

        ([key,value]) => {

          detailsContainer.innerHTML += `

            <div class="info">

              <span class="label">

                ${key}

              </span>

              <div class="value">

                ${safe(value)}

              </div>

            </div>

          `;

        }

      );

    }

    // CASE 2
    // IF BACKEND RETURNS dynamicFields

    else if(
      data.dynamicFields &&
      Array.isArray(data.dynamicFields)
    ){

      data.dynamicFields.forEach(field => {

        detailsContainer.innerHTML += `

          <div class="info">

            <span class="label">

              ${safe(field.label)}

            </span>

            <div class="value">

              ${safe(field.value)}

            </div>

          </div>

        `;

      });

    }

    else{

      detailsContainer.innerHTML = `
        <div>No additional details available</div>
      `;

    }

    // =========================
    // ATTACHMENTS
    // =========================

    const attachmentContainer =
      el('attachmentsContainer');

    attachmentContainer.innerHTML = '';

    // CASE 1
    // attachments array

    if(
      data.attachments &&
      data.attachments.length > 0
    ){

      data.attachments.forEach(file => {

        // STRING FILE

        if(typeof file === 'string'){

          attachmentContainer.innerHTML += `

            <a
              href="/uploads/${file}"
              target="_blank"
              class="attachment-link"
            >

              ${file}

            </a>

          `;

        }

        // OBJECT FILE

        else{

          attachmentContainer.innerHTML += `

            <a
              href="/uploads/${file.filename}"
              target="_blank"
              class="attachment-link"
            >

              ${safe(file.originalname || file.filename)}

            </a>

          `;

        }

      });

    }

    else{

      attachmentContainer.innerHTML = `
        <div>No attachments available</div>
      `;

    }

    // =========================
    // UPDATES HISTORY
    // =========================

    // OPTIONAL SECTION

    if(data.updates){

      const updateSection =
        document.createElement('div');

      updateSection.className =
        'card';

      updateSection.innerHTML = `
        <h3>Updates History</h3>
      `;

      data.updates.forEach(update => {

        updateSection.innerHTML += `

          <div class="update-card">

            <div>

              <strong>Status:</strong>

              ${safe(update.status)}

            </div>

            <div style="margin-top:8px;">

              <strong>Note:</strong>

              ${safe(update.resolationnote)}

            </div>

            <div style="margin-top:8px; color:#666; font-size:.9rem;">

              ${new Date(
                update.createdAt
              ).toLocaleString()}

            </div>

          </div>

        `;

      });

      el('content').appendChild(
        updateSection
      );

    }

    // =========================
    // SHOW CONTENT
    // =========================

    el('loading').style.display =
      'none';

    el('content').style.display =
      'block';

  }

  catch(err){

    console.error(err);

    el('loading').style.display =
      'none';

    el('error').style.display =
      'block';

    el('error').textContent =
      err.message;

  }

}

// =========================
// SAVE CHANGES
// =========================

el('saveBtn').addEventListener(

  'click',

  async () => {

    try{

      const payload = {

        verificationStatus:
          el('verificationStatus').value,

        priority:
          el('priority').value,

        currentStep:
          el('currentStep').value

      };

      const res = await fetch(

        `/complaint/complaints/${complaintId}/action`,

        {

          method:'POST',

          headers:{
            'Content-Type':'application/json'
          },

          body:JSON.stringify(payload)

        }

      );

      const result =
        await res.json();

      if(result.success){

        alert(
          result.message ||
          'Complaint updated successfully'
        );

        location.reload();

      }
      else{

        alert(
          result.message ||
          'Failed to update complaint'
        );

      }

    }

    catch(err){

      console.error(err);

      alert(
        'Error saving complaint'
      );

    }

  }

);

// =========================
// DELETE
// =========================

el('deleteBtn').addEventListener(

  'click',

  async () => {

    const confirmDelete =
      confirm(
        'Are you sure you want to delete this complaint?'
      );

    if(!confirmDelete){
      return;
    }

    try{

      const res = await fetch(

        `/complaint/complaints/${complaintId}/delete`,

        {
          method:'DELETE'
        }

      );

      const result =
        await res.json();

      if(result.success){

        alert(
          result.message ||
          'Complaint deleted'
        );

        window.location.href =
          '/employeeDashboard';

      }
      else{

        alert(
          result.message ||
          'Failed to delete complaint'
        );

      }

    }

    catch(err){

      console.error(err);

      alert(
        'Error deleting complaint'
      );

    }

  }

);

// =========================
// ADD UPDATE
// =========================

el('addUpdateBtn').addEventListener(

  'click',

  async () => {

    try{

      const formData =
        new FormData();

      formData.append(

        'status',

        el('updateStatus').value

      );

      formData.append(

        'resolationnote',

        el('resolutionNotes').value

      );

      const file =
        el('attachment').files[0];

      if(file){

        formData.append(
          'attachment',
          file
        );

      }

      const res = await fetch(

        `/complaint/addupdate/${complaintId}`,

        {
          method:'POST',
          body:formData
        }

      );

      const result =
        await res.json();

      if(result.success){

        alert(
          result.message ||
          'Update added successfully'
        );

        location.reload();

      }
      else{

        alert(
          result.message ||
          'Failed to add update'
        );

      }

    }

    catch(err){

      console.error(err);

      alert(
        'Error adding update'
      );

    }

  }

);

// INITIAL LOAD

loadComplaint();

</script>

</body>
</html>
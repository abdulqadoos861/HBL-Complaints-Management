<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Employee</title>
  <style>
    body { font-family: Arial, sans-serif; padding: 20px; }
    .form { max-width: 500px; display: grid; gap: 10px; }
    .form input { padding: 10px; border: 1px solid #ccc; border-radius: 6px; }
    .btn { padding: 10px; border: 0; border-radius: 6px; cursor: pointer; background: #0b5fff; color: #fff; }
    .msg { margin-top: 10px; }
  </style>
</head>
<body>
  <h1>Add Employee</h1>

  <a href="/adminDashboard">← Back to Admin Dashboard</a>

  <form class="form" id="employeeForm">
    <input name="employee_id" placeholder="Employee ID (required)" required />
    <input name="name" placeholder="Employee Name (required)" required />
    <input name="department" placeholder="Department (optional)" />
    <input name="designation" placeholder="Designation (optional)" />

    <input name="username" placeholder="Username (required)" required />
    <input name="email" placeholder="Email (required)" required type="email" />
    <input name="password" placeholder="Password (required)" required type="password" />

    <button class="btn" type="submit">Add Employee</button>
  </form>

  <div class="msg" id="message"></div>

  <script>
    const form = document.getElementById('employeeForm');
    const messageEl = document.getElementById('message');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      messageEl.textContent = 'Submitting...';

      const formData = new FormData(form);
      const payload = {};
      for (const [key, value] of formData.entries()) payload[key] = value;

      try {
        const res = await fetch('/api/admin/addemployee', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const data = await res.json().catch(() => ({}));

        if (!res.ok || !data.ok) {
          messageEl.textContent = data.message || 'Failed to add employee';
          messageEl.style.color = 'crimson';
          return;
        }

        messageEl.textContent = data.message || 'Employee added successfully';
        messageEl.style.color = 'green';

        // redirect after a short delay
        setTimeout(() => {
          window.location.href = '/adminDashboard';
        }, 400);
      } catch (err) {
        console.error(err);
        messageEl.textContent = 'Network error while adding employee';
        messageEl.style.color = 'crimson';
      }
    });
  </script>
</body>
</html>

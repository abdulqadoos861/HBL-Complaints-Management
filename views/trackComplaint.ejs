<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Track Complaint</title>
  <style>
    body { font-family: Arial; padding: 20px; }
    input { width: 320px; max-width: 100%; padding: 8px; }
    button { padding: 10px 14px; cursor:pointer; margin-left: 8px; }
    .box { border: 1px solid #ddd; padding: 14px; margin-top: 16px; border-radius: 6px; }
    .row { margin-bottom: 10px; }
    label { display:block; margin-bottom: 6px; font-weight: 600; }
    pre { background:#f6f6f6; padding: 10px; overflow:auto; }
    .error { color: #b00020; }
  </style>
</head>
<body>
  <h2>Track Complaint</h2>

  <div class="row">
    <label>Complaint Number</label>
    <input type="text" id="complaintNumber" placeholder="e.g. HBL-1234567" />
    <button id="trackBtn" type="button">Track</button>
  </div>

  <div id="result" class="box" style="display:none"></div>
  <div id="error" class="error" style="display:none"></div>

  <script>
    const complaintNumberEl = document.getElementById('complaintNumber');
    const trackBtn = document.getElementById('trackBtn');
    const resultEl = document.getElementById('result');
    const errorEl = document.getElementById('error');

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.style.display = 'block';
      resultEl.style.display = 'none';
      resultEl.innerHTML = '';
    }

    function showResult(data) {
      const c = data.complaint;
      const updates = data.updates || [];

      errorEl.style.display = 'none';
      resultEl.style.display = 'block';
      
      let html = `
        <div style="border-bottom: 2px solid #008269; padding-bottom: 10px; margin-bottom: 20px;">
          <h3 style="color: #008269;">Complaint Details: ${c.complaintNumber}</h3>
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
          <div>
            <label style="color: #666; font-size: 12px; text-transform: uppercase;">Customer Information</label>
            <div style="font-weight: bold; font-size: 16px;">${c.name}</div>
            <div style="color: #555;">CNIC: ${c.cnic || '-'}</div>
            <div style="color: #555;">Mobile: ${c.mobile || '-'}</div>
          </div>
          <div>
            <label style="color: #666; font-size: 12px; text-transform: uppercase;">Status & Priority</label>
            <div>
              <span style="background: #e9f5f0; color: #008269; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: bold;">
                ${c.currentStep}
              </span>
            </div>
            <div style="margin-top: 5px; color: #555;">Priority: <b>${c.priority || 'Medium'}</b></div>
            <div style="color: #555;">Department: <b>${c.assignedDepartment || 'Support'}</b></div>
          </div>
        </div>

        <div style="margin-bottom: 30px;">
          <label style="color: #666; font-size: 12px; text-transform: uppercase;">Subject</label>
          <div style="font-weight: bold; font-size: 18px; margin-bottom: 5px;">${c.subject}</div>
          <div style="background: #f9f9f9; padding: 15px; border-radius: 8px; border: 1px solid #eee;">
            ${c.description}
          </div>
        </div>

        <div style="border-top: 1px solid #eee; padding-top: 20px; margin-top: 20px;">
          <h3 style="color: #333; margin-bottom: 15px;">Update History</h3>
          ${updates.length === 0 ? '<p style="color: #999;">No updates yet.</p>' : `
            <div style="display: flex; flex-direction: column; gap: 15px;">
              ${updates.map(u => `
                <div style="background: white; border: 1px solid #ddd; border-left: 4px solid #008269; padding: 15px; border-radius: 6px;">
                  <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <span style="font-weight: bold; color: #008269;">${u.status}</span>
                    <span style="color: #999; font-size: 12px;">${new Date(u.createdAt).toLocaleString()}</span>
                  </div>
                  <div style="font-size: 14px; line-height: 1.5; color: #444;">
                    ${u.resolutionNotes || 'No notes provided.'}
                  </div>
                  ${u.attachments && u.attachments.length > 0 ? `
                    <div style="margin-top: 10px; padding-top: 10px; border-top: 1px dashed #eee;">
                      <label style="font-size: 11px; color: #777; text-transform: uppercase; display: block; margin-bottom: 5px;">Attachments:</label>
                      <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                        ${u.attachments.map(a => `
                          <a href="/uploads/${a.fileName}" target="_blank" style="font-size: 12px; color: #008269; text-decoration: none; background: #f0fdf4; padding: 5px 10px; border-radius: 4px; border: 1px solid #bfe3d3; display: flex; align-items: center; gap: 5px;">
                            📎 ${a.fileName}
                          </a>
                        `).join('')}
                      </div>
                    </div>
                  ` : ''}
                </div>
              `).join('')}
            </div>
          `}
        </div>

        <!-- CUSTOMER RESPONSE SECTION -->
        ${c.currentStep === 'Pending Customer Response' ? `
          <div class="box" style="background: #fff8e1; border-color: #ffc107; margin-top: 30px;">
            <h3 style="color: #856404; margin-bottom: 10px;">Action Required: Customer Response</h3>
            <p style="font-size: 14px; margin-bottom: 10px;">The bank has requested more information. Please provide your response below:</p>
            <textarea id="customerReply" style="width: 100%; height: 100px; padding: 10px; border-radius: 4px; border: 1px solid #ffc107;" placeholder="Your response here..."></textarea>
            <button id="submitReplyBtn" style="margin: 10px 0 0 0; background: #ffc107; color: #856404; font-weight: bold; border: none; padding: 10px 20px; border-radius: 4px;">Submit Response</button>
          </div>
        ` : ''}
      `;

      resultEl.innerHTML = html;

      // Attach event listener to the reply button if it exists
      const replyBtn = document.getElementById('submitReplyBtn');
      if (replyBtn) {
        replyBtn.onclick = () => submitCustomerReply(c._id);
      }
    }

    async function submitCustomerReply(complaintId) {
      const reply = document.getElementById('customerReply').value.trim();
      if (!reply) return alert('Please enter your response');

      try {
        const res = await fetch('/api/customer-reply', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ complaintId, response: reply })
        });
        
        if (res.ok) {
          alert('Response submitted successfully! Your complaint is now back in review.');
          location.reload();
        } else {
          const err = await res.json();
          alert('Error: ' + err.message);
        }
      } catch (e) {
        alert('Failed to submit response');
      }
    }

    async function track() {
      const complaintNumber = complaintNumberEl.value.trim();
      if (!complaintNumber) return showError('Please enter complaint number');

try {
        const res = await fetch(`/api/tracking/${encodeURIComponent(complaintNumber)}`);
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error(err.message || 'Failed to track complaint');
        }
        const data = await res.json();
        console.log('Tracking data:', data);
        showResult(data);
      } catch (e) {
        showError(e.message);
      }
    }

    trackBtn.addEventListener('click', track);
    complaintNumberEl.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') track();
    });

    // Auto-track if ID is provided in URL
    const urlParams = new URLSearchParams(window.location.search);
    const urlId = urlParams.get('id');
    if (urlId) {
        complaintNumberEl.value = urlId;
        track();
    }
  </script>
</body>
</html>


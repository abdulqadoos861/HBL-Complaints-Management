<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Support Dashboard</title>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family:Arial, sans-serif;
      background:#f5f5f5;
      padding:20px;
    }

    .container{
      max-width:1200px;
      margin:auto;
      background:white;
      padding:20px;
      border-radius:10px;
    }

    h1{
      margin-bottom:20px;
      color:#008269;
    }

    table{
      width:100%;
      border-collapse:collapse;
    }

    th,
    td{
      border:1px solid #ddd;
      padding:12px;
      text-align:left;
    }

    th{
      background:#008269;
      color:white;
    }

    tr:nth-child(even){
      background:#f9f9f9;
    }

    .btn{
      padding:8px 12px;
      border:none;
      border-radius:5px;
      cursor:pointer;
      color:white;
      text-decoration:none;
      display:inline-block;
      font-size:14px;
      margin-right:5px;
    }

    .open-btn{
      background:#008269;
    }

    .update-btn{
      background:#1565c0;
    }

    .empty{
      padding:16px 0;
      color:#666;
      font-size:14px;
    }

    #loading{
      text-align:center;
      padding:20px;
    }

  </style>

</head>

<body>

<div class="container">

  <div style="display: flex; justify-content: flex-end; gap: 15px; margin-bottom: 20px;">
    <a href="/profile" style="color: #008269; text-decoration: none; font-weight: bold;">My Profile</a>
    <a href="/logout" style="color: #d32f2f; text-decoration: none; font-weight: bold;">Logout</a>
  </div>

  <h1>Support Dashboard (Unverified Complaints)</h1>

  <div id="loading">
    Loading unverified complaints...
  </div>

  <table>

    <thead>

      <tr>
        <th>Complaint ID</th>
        <th>Customer Name</th>
        <th>Mobile</th>
        <th>Category</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>

    </thead>

    <tbody id="tbody"></tbody>

  </table>

  <div id="empty" class="empty" style="display:none;">
    No unverified complaints found.
  </div>

</div>

<script>

const tbody =
document.getElementById('tbody');

const loading =
document.getElementById('loading');

const emptyEl =
document.getElementById('empty');



// FETCH COMPLAINTS FROM BACKEND

async function loadComplaints(){

  try{

    const response =
    await fetch('/complaint/complaints');

    const complaints =
    await response.json();

    loading.style.display = 'none';

    // Extra safety: keep only unverified (Pending) for support UI
    const unverified = (complaints || []).filter(c =>
      c.verificationStatus === 'Pending'
    );

    if(unverified.length === 0){
      tbody.innerHTML = '';
      emptyEl.style.display = 'block';
      return;
    }

    emptyEl.style.display = 'none';

    tbody.innerHTML =
    unverified.map(c => `

      <tr>

        <td>${c._id}</td>

        <td>${c.name || '-'}</td>

        <td>${c.mobile || '-'}</td>

        <td>${c.category || '-'}</td>

        <td>${c.currentStep || '-'}</td>

        <td>

          <!-- OPEN FILE BUTTON -->

          <a
            href="/complaint/verify/${c._id}"
            class="btn open-btn"
          >
            Open File
          </a>

          <!-- VERIFY & ASSIGN BUTTON -->
          <a
            href="/complaint/verify/${c._id}"
            class="btn update-btn"
          >
            Verify & Assign
          </a>

        </td>

      </tr>

    `).join('');

  }

  catch(error){

    console.log(error);

    loading.innerHTML =
    'Failed to load complaints';

  }

}



// INITIAL LOAD

loadComplaints();

</script>

</body>
</html>

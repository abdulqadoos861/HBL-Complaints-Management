<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Add Update | HBL</title>
  <style>
    *{ margin:0; padding:0; box-sizing:border-box; }
    body{
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background:#f4f7f6;
      padding:20px;
      color:#333;
    }
    .container{ max-width:900px; margin:auto; }
    .card{
      background:#fff;
      border-radius:10px;
      box-shadow:0 2px 8px rgba(0,0,0,.05);
      padding:20px;
    }
    h1{ color:#008269; margin-bottom:14px; font-size:1.35rem; }
    .row{ display:flex; gap:14px; flex-wrap:wrap; margin-bottom:14px; }
    .field{ flex:1; min-width:240px; }
    label{ display:block; font-size:.85rem; color:#666; margin-bottom:6px; }
    input, textarea, select{
      width:100%;
      padding:12px;
      border:1px solid #ccc;
      border-radius:6px;
      font-size:1rem;
      background:#fff;
    }
    textarea{ min-height:120px; resize:vertical; }
    .actions{ display:flex; gap:12px; margin-top:18px; align-items:center; }
    button{
      background:#008269;
      color:#fff;
      border:none;
      padding:12px 18px;
      border-radius:6px;
      font-weight:bold;
      cursor:pointer;
    }
    button:disabled{ opacity:.6; cursor:not-allowed; }
    .btn-secondary{
      background:#e9f5f0;
      color:#008269;
      border:1px solid #bfe3d3;
    }
    .notice{
      margin-top:12px;
      padding:12px;
      border-radius:8px;
      display:none;
    }
    .notice.success{ background:#e8f5e9; color:#2e7d32; border:1px solid #a5d6a7; }
    .notice.error{ background:#ffebee; color:#c62828; border:1px solid #ef9a9a; }
    #currentAttachmentList{
      margin-top:10px;
      font-size:.92rem;
      color:#555;
    }
    .file-item{ margin-top:6px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <h1>Add Update for Complaint</h1>

      <!-- complaintId comes from the route: /complaint/addupdate/:complaintid -->
      <!-- Express passes :complaintid into locals ONLY if configured; so we also read it from URL -->
      <form id="updateForm">
        <input type="hidden" id="complaintId" value="<%= complaintId || '' %>"/>

        <div class="row">
          <div class="field">
            <label for="status">Status</label>
            <select id="status" name="status" required>
              <option value="" disabled selected>Select status</option>
              <option value="Submitted">Submitted</option>
              <option value="Assigned">Assigned</option>
              <option value="In Progress">In Progress</option>
              <option value="Pending Customer Response">Pending Customer Response</option>
              <option value="Resolved">Resolved</option>
              <option value="Closed">Closed</option>
            </select>
          </div>

          <div class="field">
            <label for="previousStatus">Previous Status</label>
            <input id="previousStatus" type="text" readonly style="background: #eee; cursor: not-allowed;" />
          </div>
        </div>

        <div class="row">
          <div class="field">
            <label for="resolutionNotes">Resolution Notes *</label>
            <textarea id="resolutionNotes" required placeholder="Write notes about this update..."></textarea>
          </div>
        </div>

        <div class="row">
          <div class="field">
            <label for="attachments">Attachments (optional)</label>
            <input id="attachments" type="file" multiple accept="image/*,application/pdf" />
            <div id="currentAttachmentList"></div>
            <div style="margin-top:8px; font-size:.85rem; color:#777;">
              Note: attachments will be uploaded using the endpoint’s expected payload format.
            </div>
          </div>
        </div>

        <div class="actions">
          <button type="submit" id="submitBtn">Submit Update</button>
          <a class="btn-secondary" href="/complaint/complaints" style="text-decoration:none; padding:12px 18px; border-radius:6px; display:inline-block; border:1px solid #bfe3d3;">
            Back to Complaints
          </a>
        </div>

        <div id="notice" class="notice"></div>
      </form>
    </div>
  </div>

<script>
  const form = document.getElementById('updateForm');
  const submitBtn = document.getElementById('submitBtn');
  const noticeEl = document.getElementById('notice');
  const complaintIdEl = document.getElementById('complaintId');

  const statusEl = document.getElementById('status');
  const previousStatusEl = document.getElementById('previousStatus');
  const resolutionNotesEl = document.getElementById('resolutionNotes');
  const attachmentsEl = document.getElementById('attachments');
  const attachmentListEl = document.getElementById('currentAttachmentList');

  // If complaintId isn't injected, infer from URL
  function getComplaintIdFromUrl(){
    // expected: /complaint/addupdate/:complaintid
    const parts = window.location.pathname.split('/');
    return parts[parts.length - 1] || '';
  }

  function setNotice(kind, msg){
    noticeEl.className = 'notice ' + kind;
    noticeEl.textContent = msg;
    noticeEl.style.display = 'block';
  }

  function escapeHtml(str){
    return String(str ?? '').replace(/[&<>"']/g, s => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[s]));
  }

  attachmentsEl.addEventListener('change', () => {
    const files = Array.from(attachmentsEl.files || []);
    if (!files.length){
      attachmentListEl.innerHTML = '';
      return;
    }
    attachmentListEl.innerHTML = files.map(f => (
      `<div class="file-item">${escapeHtml(f.name)} (${Math.round(f.size/1024)} KB)</div>`
    )).join('');
  });

  // INITIAL LOAD: Fetch complaint to set previous status and next status options
  async function initForm() {
    const complaintId = complaintIdEl.value || getComplaintIdFromUrl();
    if (!complaintId) return;

    try {
      const res = await fetch(`/complaint/complaints/${encodeURIComponent(complaintId)}`);
      const data = await res.json();
      const currentStatus = data.complaint ? data.complaint.currentStep : (data.currentStep || 'Submitted');
      
      previousStatusEl.value = currentStatus;

      // Define next steps logic
      const workflow = {
        'Submitted': ['Assigned', 'Pending Customer Response', 'Closed'],
        'Assigned': ['In Progress', 'Resolved', 'Closed'],
        'In Progress': ['Resolved', 'Pending Customer Response', 'Closed'],
        'Pending Customer Response': ['Submitted', 'Closed'],
        'Resolved': ['Closed', 'In Progress'],
        'Closed': [] // No next steps from Closed
      };

      const nextSteps = workflow[currentStatus] || [];
      
      // Update options
      const options = statusEl.options;
      for (let i = 0; i < options.length; i++) {
        const opt = options[i];
        if (opt.value === "") continue;
        
        if (!nextSteps.includes(opt.value)) {
          opt.disabled = true;
          opt.style.color = '#ccc';
        } else {
          opt.disabled = false;
          opt.style.color = '#333';
        }
      }
    } catch (err) {
      console.error('Failed to init form', err);
    }
  }

  initForm();

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const complaintId = complaintIdEl.value || getComplaintIdFromUrl();
    if (!complaintId){
      setNotice('error', 'Complaint ID is missing in the page URL.');
      return;
    }

    const status = statusEl.value;
    const previousstatus = previousStatusEl.value || '';
    const resolationnote = resolutionNotesEl.value; // NOTE: backend expects this misspelling

    if (!status){
      setNotice('error', 'Please select status.');
      return;
    }

    const formData = new FormData();
    formData.append('status', status);
    formData.append('previousstatus', previousstatus);
    formData.append('resolationnote', resolationnote);
    
    for (let i = 0; i < attachmentsEl.files.length; i++) {
      formData.append('attachments', attachmentsEl.files[i]);
    }

    submitBtn.disabled = true;
    setNotice('', '');

    try {
      const res = await fetch(`/complaint/addupdate/${encodeURIComponent(complaintId)}`, {
        method: 'POST',
        credentials: 'include',
        body: formData
      });

      const data = await res.json().catch(() => ({}));

      if (!res.ok){
        throw new Error(data?.message || 'Failed to submit update.');
      }

      setNotice('success', 'Update submitted successfully.');
      // optional: redirect
      setTimeout(() => window.location.href = '/complaint/complaints', 900);

    } catch (err){
      console.error(err);
      setNotice('error', err.message || 'Something went wrong.');
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>
</body>
</html>
